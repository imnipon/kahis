{
  "name": "kahis-ipscan",
  "version": "1.0.0",
  "description": "KAHIS IPScan - LAN Network Discovery Tool",
  "bin": "server/index.js",
  "pkg": {
    "targets": ["node18-win-x64"],
    "assets": [
      "node_modules/mac-oui-lookup/dist/bundle.js",
      "client/dist/**/*"
    ],
    "outputPath": "dist-exe"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "exe": "cd client && npm run build && cd .. && pkg server/index.js --config package.json --compress GZip"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mac-oui-lookup": "^1.1.4"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
